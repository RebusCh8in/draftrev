<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg: #FAF7F2;
  --bg-elevated: #F0EBE3;
  --bg-card: #FFFFFF;
  --border: #E0D8CC;
  --border-hover: #C8BEAE;
  --text-muted: #9A9185;
  --text-secondary: #6B6158;
  --text: #3D352D;
  --text-bright: #1A1510;
  --accent: #E8553A;
  --accent-hover: #D44425;
  --accent-dim: rgba(232, 85, 58, 0.06);
  --font-display: 'Instrument Serif', Georgia, serif;
  --font-body: 'Outfit', -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --container: 860px;
}

html { scroll-behavior: smooth; }

body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

::selection { background: rgba(232, 85, 58, 0.15); color: var(--text-bright); }
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--bg-elevated); }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
a { color: inherit; text-decoration: none; }
.container { max-width: var(--container); margin: 0 auto; padding: 0 2rem; }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.25rem 0;
  background: rgba(250, 247, 242, 0.9);
  backdrop-filter: blur(24px) saturate(1.4);
  -webkit-backdrop-filter: blur(24px) saturate(1.4);
  border-bottom: 1px solid var(--border);
}
nav .container { max-width: 1140px; display: flex; align-items: center; justify-content: space-between; }
.nav-logo {
  display: flex;
  align-items: center;
  text-decoration: none;
}
.nav-logo:hover { text-decoration: none; }
.nav-logo img {
  height: 26px;
  width: auto;
  display: block;
}
.nav-links { display: flex; align-items: center; gap: 2.5rem; }
.nav-links a {
  font-size: 0.9rem; font-weight: 400;
  color: var(--text-secondary);
  text-decoration: none;
  transition: color 0.3s ease;
}
.nav-links a:hover { color: var(--text-bright); text-decoration: none; }
.nav-cta {
  font-size: 0.85rem !important; font-weight: 600 !important;
  color: #FFFFFF !important;
  background: var(--accent);
  padding: 0.5rem 1.2rem;
  border-radius: 100px;
  transition: all 0.35s var(--ease-out) !important;
}
.nav-cta:hover {
  background: var(--accent-hover);
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(232, 85, 58, 0.25);
  text-decoration: none !important;
}

/* ── HERO ── */
.hero {
  padding: 8rem 0 4rem;
  border-bottom: 1px solid var(--border);
}
.breadcrumb {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}
.breadcrumb a {
  color: var(--accent);
  text-decoration: none;
  transition: color 0.2s ease;
}
.breadcrumb a:hover { color: var(--accent-hover); }
.bc-sep { color: var(--border-hover); }
.bc-current { color: var(--text-muted); }

.hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  color: var(--accent);
  margin-bottom: 1.25rem;
}

.hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.4rem, 5vw, 3.2rem);
  line-height: 1.08;
  color: var(--text-bright);
  margin-bottom: 1.5rem;
}
.hero-description {
  font-size: 1.1rem;
  line-height: 1.8;
  color: var(--text);
  font-weight: 300;
  max-width: 640px;
  margin-bottom: 2rem;
}
.hero-cta {
  display: inline-flex; align-items: center; gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 1rem; font-weight: 500;
  padding: 1rem 2rem;
  border-radius: 100px;
  border: none;
  background: var(--accent);
  color: #FFFFFF;
  text-decoration: none;
  transition: all 0.4s var(--ease-out);
}
.hero-cta:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(232, 85, 58, 0.25), 0 2px 8px rgba(232, 85, 58, 0.15);
  text-decoration: none;
}

/* ── CONTENT SECTIONS ── */
.content-section {
  padding: 5rem 0;
}
.section-alt {
  background: var(--bg-elevated);
}
.section-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.2em;
  color: var(--accent);
  margin-bottom: 1.25rem;
}
.section-title {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3.5vw, 2.2rem);
  line-height: 1.12;
  color: var(--text-bright);
  margin-bottom: 1.5rem;
}
.section-prose p {
  font-size: 1.05rem;
  line-height: 1.85;
  color: var(--text);
  font-weight: 300;
  margin-bottom: 1.5rem;
}
.section-prose strong {
  font-weight: 600;
  color: var(--text-bright);
}
.section-prose em {
  font-family: var(--font-display);
  color: var(--accent);
  font-size: 1.05em;
}
.section-prose a {
  color: var(--accent);
  text-decoration: none;
  transition: color 0.2s ease;
}
.section-prose a:hover {
  color: var(--accent-hover);
  text-decoration: underline;
}

/* ── ANSWER CAPSULE ── */
.answer-capsule {
  background: rgba(232, 85, 58, 0.04);
  border-left: 3px solid var(--accent);
  padding: 1rem 1.5rem;
  border-radius: 0 12px 12px 0;
  margin-bottom: 2rem;
  font-size: 1rem;
  line-height: 1.75;
  color: var(--text);
  font-weight: 300;
}

/* ── PAIN POINTS / PROCESS GRID ── */
.pain-grid,
.process-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin: 2rem 0;
}
.pain-card,
.step-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2rem;
  transition: all 0.4s var(--ease-out);
}
.pain-card:hover,
.step-card:hover {
  border-color: var(--border-hover);
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(26, 21, 16, 0.06);
}
.pain-card-title,
.step-title {
  font-family: var(--font-display);
  font-size: 1.25rem;
  color: var(--text-bright);
  margin-bottom: 0.75rem;
  line-height: 1.2;
}
.pain-card-desc,
.step-desc {
  font-size: 0.95rem;
  color: var(--text-secondary);
  font-weight: 300;
  line-height: 1.7;
}
.step-number {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--accent);
  margin-bottom: 1rem;
}

/* ── RESULTS CARDS ── */
.results-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  margin: 2rem 0;
}
.result-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2rem;
  transition: all 0.4s var(--ease-out);
}
.result-card:hover {
  border-color: var(--border-hover);
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(26, 21, 16, 0.06);
}
.result-label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  color: var(--accent);
  margin-bottom: 0.75rem;
}
.result-metric {
  font-family: var(--font-display);
  font-size: 2.5rem;
  color: var(--text-bright);
  line-height: 1;
  margin-bottom: 0.25rem;
}
.result-unit {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-bottom: 0.75rem;
}
.result-desc {
  font-size: 0.92rem;
  color: var(--text-secondary);
  font-weight: 300;
  line-height: 1.65;
}
.results-note {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  margin-top: 1rem;
}

/* ── CTA SECTION (dark) ── */
.cta-section {
  background: var(--text-bright);
  color: #F5F0E8;
  padding: 6rem 0;
  position: relative;
  overflow: hidden;
  text-align: center;
}
.cta-section::before {
  content: '';
  position: absolute;
  top: -1px;
  left: 0;
  right: 0;
  height: 80px;
  background: linear-gradient(to bottom, var(--bg), var(--text-bright));
  pointer-events: none;
}
.cta-section::after {
  content: '';
  position: absolute;
  bottom: -1px;
  left: 0;
  right: 0;
  height: 80px;
  background: linear-gradient(to top, var(--bg-elevated), var(--text-bright));
  pointer-events: none;
}
.cta-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  color: var(--accent);
  margin-bottom: 1.25rem;
}
.cta-headline {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3.5vw, 2.4rem);
  line-height: 1.15;
  color: #FFFFFF;
  margin-bottom: 1rem;
}
.cta-headline em {
  font-family: var(--font-display);
  color: var(--accent);
}
.cta-sub {
  font-size: 1.05rem;
  color: rgba(245, 240, 232, 0.6);
  font-weight: 300;
  margin-bottom: 2rem;
  line-height: 1.75;
}
.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 500;
  padding: 1.1rem 2.5rem;
  border-radius: 100px;
  border: none;
  background: var(--accent);
  color: #FFFFFF;
  text-decoration: none;
  transition: all 0.4s var(--ease-out);
}
.cta-btn:hover {
  background: var(--accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(232, 85, 58, 0.35), 0 2px 8px rgba(232, 85, 58, 0.2);
  text-decoration: none;
}

/* ── FAQ ACCORDION ── */
.faq-list {
  max-width: 860px;
}
.faq-item {
  border-bottom: 1px solid var(--border);
}
.faq-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 1.4rem 0;
  cursor: pointer;
}
.faq-header:hover .faq-q { color: var(--text-bright); }
.faq-q {
  font-family: var(--font-display);
  font-size: 1.2rem;
  color: var(--text);
  transition: color 0.3s ease;
  line-height: 1.3;
  padding-right: 1rem;
}
.faq-toggle {
  width: 30px; height: 30px;
  display: flex; align-items: center; justify-content: center;
  border: 1px solid var(--border);
  border-radius: 50%;
  flex-shrink: 0;
  transition: all 0.3s ease;
}
.faq-toggle svg {
  width: 12px; height: 12px;
  stroke: var(--text-secondary);
  transition: all 0.3s ease;
}
.faq-item.open .faq-toggle {
  background: var(--accent-dim);
  border-color: rgba(232, 85, 58, 0.25);
}
.faq-item.open .faq-toggle svg {
  transform: rotate(45deg);
  stroke: var(--accent);
}
.faq-body {
  max-height: 0; overflow: hidden;
  transition: max-height 0.5s var(--ease-out);
}
.faq-item.open .faq-body { max-height: 400px; }
.faq-answer {
  font-size: 0.95rem;
  color: var(--text);
  font-weight: 300;
  line-height: 1.85;
  padding-bottom: 1.5rem;
}

/* ── FINAL CTA ── */
.final-cta {
  padding: 6rem 0;
  text-align: center;
}
.final-cta .section-eyebrow { margin-bottom: 1rem; }
.final-headline {
  font-family: var(--font-display);
  font-size: clamp(1.8rem, 3.5vw, 2.4rem);
  line-height: 1.15;
  color: var(--text-bright);
  margin-bottom: 1rem;
}
.final-headline em {
  font-family: var(--font-display);
  color: var(--accent);
}
.final-sub {
  font-size: 1.05rem;
  color: var(--text-secondary);
  font-weight: 300;
  margin-bottom: 2rem;
  line-height: 1.75;
}
.final-cta .hero-cta {
  font-size: 1.05rem;
  padding: 1.1rem 2.5rem;
}

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--border);
  padding: 3rem 0 2rem;
}
footer .container { max-width: 1140px; }
.footer-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 2rem;
  margin-bottom: 2rem;
}
.footer-brand-name img {
  height: 18px;
  width: auto;
  display: block;
}
.footer-heading {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--text-secondary);
  margin-bottom: 0.75rem;
}
.footer-links {
  list-style: none;
  padding: 0;
}
.footer-links li { margin-bottom: 0.35rem; }
.footer-links a {
  font-size: 0.85rem;
  font-weight: 300;
  color: var(--text);
  transition: color 0.2s ease;
}
.footer-links a:hover { color: var(--accent); }
.footer-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
}
.footer-copy { font-size: 0.75rem; color: var(--text-muted); }

/* ── MOBILE NAV ── */
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  padding: 0.5rem;
  cursor: pointer;
  z-index: 102;
}
.nav-toggle span {
  display: block;
  width: 22px;
  height: 2px;
  background: var(--text-bright);
  border-radius: 2px;
  transition: all 0.3s var(--ease-out);
}
.nav-toggle.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
