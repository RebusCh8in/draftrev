  margin-right: auto;
}
.cta-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-size: 1.05rem;
  font-weight: 500;
  padding: 1.1rem 2.5rem;
  border-radius: 100px;
  border: none;
  background: var(--accent);
  color: #FFFFFF;
  text-decoration: none;
  transition: all 0.4s var(--ease-out);
}
.cta-btn:hover {
  background: var(--accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 8px 32px rgba(232, 85, 58, 0.35), 0 2px 8px rgba(232, 85, 58, 0.2);
  text-decoration: none;
