  letter-spacing: 0.12em;
  color: var(--text-muted);
  margin-bottom: 0.35rem;
}

/* -- SCENARIO CARDS (When X Wins) -- */
.scenario-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1.5rem;
  margin: 2rem 0;
}
.scenario-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2rem;
  transition: all 0.4s var(--ease-out);
}
.scenario-card:hover {
  border-color: var(--border-hover);
  transform: translateY(-4px);
  box-shadow: 0 16px 48px rgba(26, 21, 16, 0.06);
}
.scenario-label {
  font-family: var(--font-mono);
  font-size: 0.62rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.12em;
  margin-bottom: 1rem;
}
.scenario-label.cold-email { color: var(--text-secondary); }
.scenario-label.linkedin { color: var(--accent); }
.scenario-card-title {
  font-family: var(--font-display);
  font-size: 1.25rem;
  color: var(--text-bright);
  margin-bottom: 1rem;
  line-height: 1.2;
}
.scenario-card ul {
  list-style: none;
  padding: 0;
}
.scenario-card li {
  font-size: 0.95rem;
  color: var(--text);
  font-weight: 300;
  line-height: 1.7;
  padding: 0.4rem 0;
  padding-left: 1.5rem;
  position: relative;
}
.scenario-card li::before {
  position: absolute;
  left: 0;
  font-weight: 600;
}
.scenario-cold li::before {
  content: "\2192";
  color: var(--text-muted);
}
.scenario-linkedin li::before {
  content: "\2713";
  color: var(--accent);
}

/* -- BEST APPROACH BLOCK -- */
.approach-block {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2.5rem;
  margin: 2rem 0;
}
.approach-block p {
  font-size: 1.05rem;
  line-height: 1.85;
  color: var(--text);
  font-weight: 300;
  margin-bottom: 1rem;
}
.approach-block p:last-child { margin-bottom: 0; }
.approach-block strong {
