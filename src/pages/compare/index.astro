<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --bg: #FAF7F2;
  --bg-elevated: #F0EBE3;
  --bg-card: #FFFFFF;
  --border: #E0D8CC;
  --border-hover: #C8BEAE;
  --text-muted: #9A9185;
  --text-secondary: #6B6158;
  --text: #3D352D;
  --text-bright: #1A1510;
  --accent: #E8553A;
  --accent-hover: #D44425;
  --accent-dim: rgba(232, 85, 58, 0.06);
  --font-display: 'Instrument Serif', Georgia, serif;
  --font-body: 'Outfit', -apple-system, sans-serif;
  --font-mono: 'JetBrains Mono', monospace;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
}

html { font-size: 16px; -webkit-font-smoothing: antialiased; }
body {
  font-family: var(--font-body);
  background: var(--bg);
  color: var(--text);
  overflow-x: hidden;
  line-height: 1.6;
}
a { text-decoration: none; color: inherit; }
img { max-width: 100%; display: block; }
.container { max-width: 1100px; margin: 0 auto; padding: 0 2rem; }

/* ── NAV ── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  padding: 1.25rem 0;
  transition: all 0.5s var(--ease-out);
}
nav.scrolled {
  background: rgba(250, 247, 242, 0.9);
  backdrop-filter: blur(24px) saturate(1.4);
  -webkit-backdrop-filter: blur(24px) saturate(1.4);
  border-bottom: 1px solid var(--border);
  padding: 0.85rem 0;
}
nav .container { display: flex; align-items: center; justify-content: space-between; }
.nav-logo { display: flex; align-items: center; }
.nav-logo img { height: 26px; width: auto; display: block; }
.nav-links { display: flex; align-items: center; gap: 2.5rem; }
.nav-links a {
  font-size: 0.9rem; font-weight: 400;
  color: var(--text-secondary);
  transition: color 0.3s ease;
}
.nav-links a:hover { color: var(--text-bright); }
.nav-cta {
  font-size: 0.85rem !important; font-weight: 600 !important;
  color: #FFFFFF !important;
  background: var(--accent);
  padding: 0.5rem 1.2rem;
  border-radius: 100px;
  transition: all 0.35s var(--ease-out) !important;
}
.nav-cta:hover {
  background: var(--accent-hover);
  transform: translateY(-1px);
  box-shadow: 0 4px 20px rgba(232, 85, 58, 0.25);
}
.nav-toggle {
  display: none; background: none; border: none; cursor: pointer;
  flex-direction: column; gap: 5px; padding: 4px;
}
.nav-toggle span {
  display: block; width: 22px; height: 2px;
  background: var(--text-bright); border-radius: 2px;
  transition: all 0.3s ease;
}

/* ── BREADCRUMB ── */
.bc {
  padding-top: 8rem;
  font-family: var(--font-mono);
  font-size: 0.72rem; font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  color: var(--text-muted);
}
.bc a { color: var(--text-muted); transition: color 0.3s ease; }
.bc a:hover { color: var(--accent); }
.bc-sep { margin: 0 0.5rem; color: var(--border); }
.bc-current { color: var(--text-secondary); }

/* ── HERO ── */
.hub-hero {
  padding: 2rem 0 3rem;
}
.hub-hero-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.68rem; font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  color: var(--accent);
  margin-bottom: 1.25rem;
}
.hub-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(2.6rem, 6vw, 4.5rem);
  line-height: 1.05;
  color: var(--text-bright);
  margin-bottom: 1.5rem;
  max-width: 900px;
}
.hub-hero-sub {
  font-size: 1.2rem;
  color: var(--text-secondary);
  font-weight: 300;
  max-width: 680px;
  line-height: 1.55;
}

/* ── GRID ── */
.hub-grid-section { padding: 2rem 0 6rem; }
.hub-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
}
.hub-card {
  display: flex;
  flex-direction: column;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 2.5rem;
  transition: all 0.4s var(--ease-out);
  position: relative;
  overflow: hidden;
}
.hub-card::after {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 20px;
  border: 1px solid transparent;
  transition: border-color 0.4s var(--ease-out);
  pointer-events: none;
}
.hub-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.06);
}
.hub-card:hover::after { border-color: var(--border-hover); }

.hub-card-tag {
  font-family: var(--font-mono);
  font-size: 0.65rem; font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.22em;
  color: var(--accent);
  margin-bottom: 1.5rem;
}
.hub-card h2 {
  font-family: var(--font-display);
  font-size: 2rem;
  line-height: 1.15;
  color: var(--text-bright);
  margin-bottom: 1rem;
}
.hub-card p {
  font-size: 0.98rem;
  color: var(--text-secondary);
  line-height: 1.6;
  margin-bottom: 2rem;
  flex: 1;
}
.hub-card-arrow {
  font-family: var(--font-body);
  font-size: 0.95rem; font-weight: 600;
  color: var(--accent);
  display: inline-flex; align-items: center; gap: 0.5rem;
  transition: gap 0.3s var(--ease-out);
}
.hub-card:hover .hub-card-arrow { gap: 0.85rem; }

/* ── CTA BAND ── */
.hub-cta {
  padding: 5rem 0 7rem;
  text-align: center;
  border-top: 1px solid var(--border);
}
.hub-cta h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 2.8rem);
  line-height: 1.15;
  color: var(--text-bright);
  margin-bottom: 1rem;
}
.hub-cta p {
  font-size: 1.1rem;
  color: var(--text-secondary);
  max-width: 560px;
  margin: 0 auto 2.5rem;
}
.hub-cta-btn {
  display: inline-flex; align-items: center; gap: 0.75rem;
  font-family: var(--font-body);
  font-size: 1.1rem; font-weight: 700;
  padding: 1.1rem 2.75rem; border-radius: 100px;
  background: var(--accent); color: #FFFFFF;
  transition: all 0.4s var(--ease-out);
  box-shadow: 0 4px 24px rgba(232, 85, 58, 0.2);
}
.hub-cta-btn:hover {
  background: var(--accent-hover);
  transform: translateY(-3px);
  box-shadow: 0 12px 48px rgba(232, 85, 58, 0.35);
}

/* ── FOOTER ── */
footer {
  border-top: 1px solid var(--border);
  padding: 4.5rem 0 3rem;
}
.footer-grid {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
  gap: 3rem;
}
.footer-brand-name { margin-bottom: 0.35rem; }
.footer-brand-name img { height: 18px; width: auto; display: block; }
.footer-heading {
  font-family: var(--font-mono);
  font-size: 0.62rem; font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.18em;
  color: var(--text-muted);
  margin-bottom: 1.25rem;
}
.footer-links { list-style: none; }
.footer-links li { margin-bottom: 0.6rem; }
.footer-links a { font-size: 0.85rem; color: var(--text); transition: color 0.3s ease; }
.footer-links a:hover { color: var(--accent); }
.footer-bottom {
  margin-top: 3.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.footer-copy { font-size: 0.75rem; color: var(--text-muted); }

/* ── RESPONSIVE ── */
@media (max-width: 900px) {
  .hub-grid { grid-template-columns: 1fr; gap: 1.25rem; }
}
@media (max-width: 768px) {
  .nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: rgba(250, 247, 242, 0.95); backdrop-filter: blur(24px); padding: 1.5rem 2rem; gap: 1rem; border-bottom: 1px solid var(--border); }
  .nav-links.open { display: flex; }
  .nav-toggle { display: flex; }
  .bc { padding-top: 6.5rem; }
  .hub-card { padding: 2rem; }
  .hub-card h2 { font-size: 1.65rem; }
  .footer-grid { grid-template-columns: 1fr 1fr; }
  .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
}
@media (max-width: 480px) {
  .container { padding: 0 1.25rem; }
  .footer-grid { grid-template-columns: 1fr; }
}
</style>
</head>
